---
---
<!-- Navbar -->
<div class="fixed top-0 z-50 flex justify-center w-full">
  <nav class="w-[92%] max-w-7xl bg-dark/80 backdrop-blur-xl rounded-b-3xl px-8 py-3.5 flex items-center justify-between border border-light/[0.08] border-t-0 shadow-2xl shadow-black/40">
    <!-- Logo -->
    <a href="/" class="signature font-signature text-4xl text-primary leading-none select-none hover:scale-105 transition-transform">
      Kigen
    </a>
    
    <!-- Nav Pills -->
    <ul class="flex gap-1.5 text-sm">
      <li>
        <a href="/" class="relative px-5 py-2 rounded-xl font-semibold inline-block text-light overflow-hidden group">
          <span class="absolute inset-0 bg-primary/15 border border-primary/25"></span>
          <span class="relative z-10">Home</span>
        </a>
      </li>
      <li>
        <a href="#about" class="px-5 py-2 rounded-xl font-medium inline-block text-light/50 hover:text-light hover:bg-light/5 transition-all">About</a>
      </li>
      <li>
        <a href="/blog" class="px-5 py-2 rounded-xl font-medium inline-block text-light/50 hover:text-light hover:bg-light/5 transition-all">Blog</a>
      </li>
      <li>
        <a href="#contact" class="px-5 py-2 rounded-xl font-medium inline-block text-light/50 hover:text-light hover:bg-light/5 transition-all">Contact</a>
      </li>
    </ul>
    
    <!-- CTA -->
    <div class="flex items-center gap-3">
      <button
        id="theme-toggle"
        aria-label="Toggle dark/light mode"
        class="w-9 h-9 flex items-center justify-center rounded-xl border border-light/10 text-light/50 hover:text-light hover:border-light/30 hover:bg-light/5 transition-all"
      >
        <!-- Sun icon (shown in dark mode) -->
        <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" class="w-4.5 h-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <!-- Moon icon (shown in light mode) -->
        <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" class="w-4.5 h-4.5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>

      <a
        href="/Nathan_Kibet_CV.pdf"
        download
        class="bg-primary text-dark text-sm font-bold px-6 py-2.5 rounded-xl hover:bg-primary/90 hover:shadow-lg hover:shadow-primary/30 transition-all hover:-translate-y-0.5"
      >
        Download CV ↓
      </a>
    </div>
  </nav>
</div>

<script>
  const html = document.documentElement;
  const btn = document.getElementById('theme-toggle')!;
  const sun = document.getElementById('icon-sun')!;
  const moon = document.getElementById('icon-moon')!;

  function applyTheme(isLight: boolean) {
    html.classList.toggle('light', isLight);
    sun.classList.toggle('hidden', isLight);
    moon.classList.toggle('hidden', !isLight);
  }

  // Sync icon state on load
  applyTheme(html.classList.contains('light'));

  btn.addEventListener('click', () => {
    html.classList.add('theme-transition');
    const isLight = !html.classList.contains('light');
    applyTheme(isLight);
    localStorage.setItem('theme', isLight ? 'light' : 'dark');
    setTimeout(() => html.classList.remove('theme-transition'), 200);
  });
</script>


