---
const year = new Date().getFullYear();

const nav = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '#about' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contact', href: '#contact' },
];

const socials = [
  {
    label: 'GitHub',
    href: 'https://github.com/nathandekibet',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>`,
  },
  {
    label: 'LinkedIn',
    href: 'https://linkedin.com/in/nathandekibet',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  },
  {
    label: 'X / Twitter',
    href: 'https://x.com/nathandekibet',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.259 5.63L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/></svg>`,
  },
];
---

<footer class="bg-dark border-t border-light/[0.08]">
  <div class="max-w-7xl mx-auto px-8 py-16">

    <div class="grid grid-cols-12 gap-8 pb-12 border-b border-light/[0.06]">

      <!-- Logo + tagline -->
      <div class="col-span-5 flex flex-col gap-4">
        <a href="/" class="signature font-signature text-5xl text-primary leading-none select-none hover:scale-105 transition-transform inline-block w-fit">
          Kigen
        </a>
        <p class="text-light/40 text-sm leading-relaxed max-w-xs">
          Full stack developer building clean, scalable web solutions from Nairobi, Kenya.
        </p>
        <!-- Socials -->
        <div class="flex items-center gap-3 pt-2">
          {socials.map(s => (
            <a
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={s.label}
              class="w-9 h-9 flex items-center justify-center rounded-xl border border-light/10 text-light/40 hover:text-light hover:border-light/30 hover:bg-light/5 transition-all"
              set:html={s.icon}
            />
          ))}
        </div>
      </div>

      <!-- Spacer -->
      <div class="col-span-1" />

      <!-- Navigation -->
      <div class="col-span-3">
        <p class="text-light/20 text-[0.65rem] uppercase tracking-[0.3em] font-bold mb-4">Navigation</p>
        <ul class="space-y-2.5">
          {nav.map(link => (
            <li>
              <a href={link.href} class="text-light/50 hover:text-light text-sm font-medium transition-colors hover:translate-x-0.5 inline-flex items-center gap-1.5 group">
                <span class="w-3 h-px bg-primary/50 group-hover:w-5 group-hover:bg-primary transition-all duration-300"></span>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Availability -->
      <div class="col-span-3">
        <p class="text-light/20 text-[0.65rem] uppercase tracking-[0.3em] font-bold mb-4">Status</p>
        <div class="space-y-3">
          <div class="flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-accent animate-pulse shadow-lg shadow-accent/50"></span>
            <span class="text-accent text-sm font-semibold">Available for Work</span>
          </div>
          <p class="text-light/30 text-xs leading-relaxed">Open to full-time roles and freelance projects globally.</p>
          <a
            href="#contact"
            class="inline-flex items-center gap-2 text-xs font-bold text-primary hover:text-primary/80 uppercase tracking-wider transition-colors group"
          >
            Get in touch
            <span class="group-hover:translate-x-0.5 transition-transform">→</span>
          </a>
        </div>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="pt-6 flex items-center justify-between">
      <p class="text-light/20 text-xs">
        © {year} Nathan Kibet. All rights reserved.
      </p>
      <p class="text-light/15 text-xs font-mono">
        Built with Astro + React
      </p>
    </div>

  </div>
</footer>

<style>
  .signature {
    display: inline-block;
    transform: rotate(-3deg);
    position: relative;
  }
  .signature::after {
    content: '';
    position: absolute;
    bottom: 2px;
    left: 6px;
    right: 10px;
    height: 2px;
    background: var(--color-primary);
    border-radius: 9999px;
    opacity: 0.4;
    transform: rotate(2deg);
  }
</style>
