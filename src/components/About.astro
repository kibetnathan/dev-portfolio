---
import EducationRoadmap from "./EducationRoadmap.jsx";

const topSkills = [
  { name: 'JavaScript', slug: 'javascript', color: 'F7DF1E' },
  { name: 'React/Preact', slug: 'react', color: '61DAFB' },
  { name: 'Python', slug: 'python', color: '3776AB' },
  { name: 'Django/DRF', slug: 'django', color: '092E20' },
  { name: 'PostgreSQL', slug: 'postgresql', color: '4169E1' },
];

const otherSkills = [
  { name: 'Astro', slug: 'astro', color: 'FF5D01' },
  { name: 'TypeScript', slug: 'typescript', color: '3178C6' },
  { name: 'C', slug: 'c', color: 'A8B9CC' },
  { name: 'PHP', slug: 'php', color: '777BB4' },
  { name: 'Laravel', slug: 'laravel', color: 'FF2D20' },
  { name: 'Node.js', slug: 'nodedotjs', color: '5FA04E' },
  { name: 'Bash', slug: 'gnubash', color: '4EAA25' },
  { name: 'Redux', slug: 'redux', color: '764ABC' },
  { name: 'Zustand', slug: 'react', color: '61DAFB' }, // No official icon, using React
  { name: 'Canva', slug: 'canva', color: '00C4CC' },
  { name: 'Affinity', slug: 'affinity', color: '222222' },
  { name: 'Krita', slug: 'krita', color: '35A6FF' },
  { name: 'Figma', slug: 'figma', color: 'F24E1E' },
  { name: 'Vim', slug: 'vim', color: '019733' },
  { name: 'SQL', slug: 'sqlite', color: '003B57' },
];
---

<section id="about" class="relative pt-32 pb-16 bg-dark overflow-hidden">
  
  <!-- Background Accents for About Card -->
  <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-primary/5 rounded-full blur-[120px] -mr-64 -mt-32"></div>
  <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-secondary/5 rounded-full blur-[120px] -ml-64 -mb-32"></div>

  <div class="max-w-7xl mx-auto px-8 relative z-10">
    <div class="grid grid-cols-12 gap-16 items-center">
      
      <!-- Left: Picture & Layered Effect -->
      <div class="col-span-12 lg:col-span-5 relative group">
        <!-- Background Layered Card 1 -->
        <div class="absolute -inset-4 bg-primary/20 rounded-3xl rotate-3 scale-105 blur-sm group-hover:rotate-6 transition-transform duration-500"></div>
        <!-- Background Layered Card 2 -->
        <div class="absolute -inset-4 border-2 border-light/10 rounded-3xl -rotate-2 group-hover:-rotate-4 transition-transform duration-500"></div>
        
        <!-- Main Image Container -->
        <div class="relative rounded-2xl overflow-hidden aspect-[3/4] shadow-2xl border border-light/20 bg-dark">
          <img 
            src="/full_body.png" 
            alt="Nathan Kibet" 
            class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700 scale-105 group-hover:scale-100 object-top"
          />
          <!-- Floating Label -->
          <div class="absolute bottom-6 left-6 right-6 p-4 bg-dark/60 backdrop-blur-md border border-light/10 rounded-xl">
             <p class="font-display text-2xl text-light uppercase tracking-wide">Nathan Kibet</p>
             <p class="text-primary text-[0.65rem] font-bold uppercase tracking-[0.2em]">Full Stack Engineer</p>
          </div>
        </div>
      </div>

      <!-- Right: Content & Layered Cards -->
      <div class="col-span-12 lg:col-span-7 relative">
        
        <!-- Layered Cards behind the text -->
        <div class="absolute -top-10 -right-10 w-64 h-64 border border-primary/20 rounded-full opacity-20 animate-pulse"></div>
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[110%] h-[120%] bg-light/[0.02] -rotate-1 rounded-[40px] border border-light/5 pointer-events-none"></div>
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[105%] h-[110%] bg-light/[0.01] rotate-1 rounded-[40px] border border-light/5 pointer-events-none"></div>

        <div class="relative space-y-10">
          
          <!-- Professional Section -->
          <div class="space-y-4">
            <h2 class="font-display text-7xl text-light leading-none uppercase tracking-tighter">
              Crafting <br />
              <span class="text-primary">Digital Excellence</span>
            </h2>
            <div class="h-1.5 w-24 bg-primary rounded-full"></div>
            <p class="text-light/80 text-xl leading-relaxed font-medium">
              I am a results-driven Full Stack Developer with a deep-seated passion for architecting 
              scalable, high-performance web applications. My expertise lies in bridging the gap between 
              complex backend logic and intuitive, visually stunning frontend experiences.
            </p>
            <p class="text-light/60 text-lg leading-relaxed">
              With a strong foundation in <span class="text-secondary font-semibold">JavaScript, React, Python, and Django</span>, 
              I specialize in building tools that aren't just functional, but are a joy to use. I thrive in 
              environments that challenge me to solve intricate problems and push the boundaries of modern web standards.
            </p>
          </div>

          <!-- Interests & Hobbies Section -->
          <div class="pt-6 border-t border-light/10">
            <h3 class="font-display text-3xl text-light uppercase tracking-tight mb-4 flex items-center gap-3">
               Beyond the Code
               <span class="flex-grow h-px bg-light/10"></span>
            </h3>
            <div class="grid grid-cols-2 gap-6">
               <div class="space-y-2">
                  <p class="text-primary font-bold text-xs uppercase tracking-widest">Interests</p>
                  <p class="text-light/60 text-sm leading-relaxed">
                    Low-level systems programming (C), brutalist graphic design, and technical blogging about computer history and modern architecture. Currently in the Studienbrücke program (B2/C1 German).
                  </p>
               </div>
               <div class="space-y-2">
                  <p class="text-secondary font-bold text-xs uppercase tracking-widest">Hobbies</p>
                  <p class="text-light/60 text-sm leading-relaxed">
                    Traditional anatomical drawing, bodybuilding, golf, and fashion. I'm also actively involved in arts and social development communities.
                  </p>
               </div>
            </div>
          </div>

          <!-- Signature/Closing -->
          <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6 pt-10 border-t border-light/10">
             <div class="flex items-center gap-4">
                <div class="w-14 h-14 rounded-full border border-light/20 flex items-center justify-center font-signature text-2xl text-accent bg-light/5">
                  NK
                </div>
                <div>
                  <p class="text-light font-bold text-sm uppercase tracking-widest">Based in Nairobi</p>
                  <p class="text-light/30 text-[0.65rem] uppercase tracking-widest font-bold">Open for Global Opportunities</p>
                </div>
             </div>

             <!-- Obfuscated Reveal Email -->
             <div class="relative group">
               <button 
                 id="reveal-email"
                 class="flex flex-col items-start gap-1 px-6 py-3 bg-light/5 border border-light/10 rounded-2xl hover:border-primary/50 hover:bg-light/10 transition-all duration-300 group"
               >
                 <span class="text-[0.6rem] text-primary font-black uppercase tracking-[0.2em] mb-1">Contact Me</span>
                 <div class="flex items-center gap-3">
                   <span id="email-display" class="font-mono text-light/40 text-sm tracking-wider">na...[at]...dev</span>
                   <div id="reveal-icon" class="p-1.5 bg-primary/10 rounded-lg group-hover:bg-primary transition-colors">
                     <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-primary group-hover:text-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                       <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                       <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                     </svg>
                   </div>
                 </div>
                 <!-- Tooltip -->
                 <span class="absolute -top-8 left-1/2 -translate-x-1/2 px-3 py-1 bg-primary text-dark text-[0.6rem] font-bold rounded opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none whitespace-nowrap">
                   Click to reveal & copy
                 </span>
               </button>
             </div>
          </div>

        </div>
      </div>
    </div>
  </div>

  <!-- Separate Skills Section Below -->
  <div class="max-w-7xl mx-auto px-8 mt-24 relative z-10">
    <div class="bg-light/[0.02] border border-light/5 rounded-[40px] p-12 relative overflow-hidden group/skills">
      <!-- Background Glow for Skills Section -->
      <div class="absolute -bottom-24 -right-24 w-96 h-96 bg-primary/10 rounded-full blur-[100px] pointer-events-none opacity-0 group-hover/skills:opacity-100 transition-opacity duration-700"></div>
      
      <div class="grid grid-cols-12 gap-12">
        <!-- Section Header -->
        <div class="col-span-12 lg:col-span-4">
          <div class="sticky top-8">
            <p class="text-primary text-[0.65rem] tracking-[0.4em] uppercase font-black mb-4 flex items-center gap-3">
              <span class="w-10 h-[2px] bg-primary/30"></span>
              Tech Stack
            </p>
            <h2 class="font-display text-6xl text-light leading-[0.9] uppercase tracking-tighter mb-6">
              THE TOOLS <br />
              <span class="text-primary/50">OF THE TRADE</span>
            </h2>
            <p class="text-light/50 text-sm leading-relaxed max-w-xs">
              A comprehensive list of technologies and tools I leverage to bring complex digital visions to life.
            </p>
          </div>
        </div>

        <!-- Skills Content -->
        <div class="col-span-12 lg:col-span-8 space-y-12">
          <!-- Top Skills Grid -->
          <div>
            <h3 class="text-light/30 text-[0.65rem] font-black uppercase tracking-[0.3em] mb-8 flex items-center gap-4">
              Core Expertise
              <span class="flex-grow h-px bg-light/5"></span>
            </h3>
            <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
              {topSkills.map(skill => (
                <div class="bg-light/5 border border-light/10 p-5 rounded-3xl flex flex-col items-center gap-4 group hover:border-primary/50 hover:bg-primary/5 transition-all duration-300 hover:-translate-y-1">
                  <div class="p-3 bg-dark/50 rounded-2xl group-hover:scale-110 transition-transform">
                    <img 
                      src={`https://cdn.simpleicons.org/${skill.slug}/${skill.color}`} 
                      alt={skill.name}
                      class="w-8 h-8"
                    />
                  </div>
                  <span class="text-[0.6rem] font-black uppercase tracking-widest text-light/50 group-hover:text-primary transition-colors text-center">{skill.name}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- Skills Wall -->
          <div>
            <h3 class="text-light/30 text-[0.65rem] font-black uppercase tracking-[0.3em] mb-6 flex items-center gap-4">
              Development Stack & Software
              <span class="flex-grow h-px bg-light/5"></span>
            </h3>
            <div class="flex flex-wrap gap-3">
              {otherSkills.map(skill => (
                <div class="flex items-center gap-2.5 px-5 py-2.5 bg-light/[0.03] border border-light/5 rounded-2xl hover:border-light/20 hover:bg-light/10 transition-all group cursor-default hover:-translate-y-0.5">
                  <img 
                    src={`https://cdn.simpleicons.org/${skill.slug}/${skill.color}`} 
                    alt={skill.name}
                    class="w-4 h-4 grayscale opacity-40 group-hover:grayscale-0 group-hover:opacity-100 transition-all"
                  />
                  <span class="text-xs font-bold text-light/30 group-hover:text-light transition-colors">{skill.name}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Education & Experience Section -->
  <div class="max-w-7xl mx-auto px-8 mt-24 pb-24 relative z-10">
    <div class="grid grid-cols-12 gap-16">
      
      <!-- Left: Experience (Capstone) -->
      <div class="col-span-12 lg:col-span-6 space-y-10">
        <div>
          <p class="text-accent text-[0.65rem] tracking-[0.4em] uppercase font-black mb-4 flex items-center gap-3">
            <span class="w-10 h-[2px] bg-accent/30"></span>
            Professional Journey
          </p>
          <h2 class="font-display text-6xl text-light leading-none uppercase tracking-tighter">
            Experience & <br />
            <span class="text-accent">Milestones</span>
          </h2>
        </div>

        <div class="relative p-8 bg-light/[0.02] border border-light/5 rounded-[32px] group hover:border-accent/30 transition-all duration-500">
          <div class="absolute top-0 right-0 p-6 opacity-10 group-hover:opacity-20 transition-opacity">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-24 h-24" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
          </div>
          
          <div class="space-y-4 relative z-10">
            <div class="flex items-center justify-between">
              <span class="px-3 py-1 bg-accent/10 text-accent text-[0.6rem] font-black uppercase tracking-widest rounded-lg">Capstone Project</span>
              <span class="text-light/30 text-xs font-mono">Zindua School</span>
            </div>
            <h3 class="font-display text-3xl text-light uppercase tracking-tight">Open Church Management</h3>
            <p class="text-light/60 text-sm leading-relaxed">
              Developed an open-source community management platform designed to handle member records and organizational workflows for religious institutions.
            </p>
            <ul class="space-y-2">
              {[
                'Architected database schemas for member records',
                'Built responsive frontend for administrative staff',
                'Optimized organizational workflows',
                'Open-source community management focus'
              ].map(item => (
                <li class="flex items-center gap-2 text-xs text-light/40">
                  <span class="w-1.5 h-1.5 rounded-full bg-accent/50"></span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>

      <!-- Right: Education Roadmap -->
      <div class="col-span-12 lg:col-span-6">
        <h3 class="text-light/30 text-[0.65rem] font-black uppercase tracking-[0.3em] mb-12 flex items-center gap-4">
          Education Roadmap
          <span class="flex-grow h-px bg-light/5"></span>
        </h3>

        <EducationRoadmap client:visible />
      </div>
    </div>
  </div>

  <!-- Final Call to Action / Opportunities Footer -->
  <div class="max-w-7xl mx-auto px-8 pb-32 relative z-10">
    <div class="relative group">
      <div class="absolute inset-0 bg-gradient-to-r from-primary/10 via-accent/10 to-secondary/10 rounded-[40px] blur-2xl opacity-50 group-hover:opacity-100 transition-opacity duration-1000"></div>
      <div class="relative bg-dark/50 backdrop-blur-xl border border-light/10 rounded-[40px] p-12 text-center space-y-8 overflow-hidden">
        <div class="space-y-4">
          <h2 class="font-display text-5xl md:text-6xl text-light uppercase tracking-tighter">
            Let's Build Something <span class="text-primary">Exceptional</span>
          </h2>
          <p class="text-light/60 text-lg max-w-2xl mx-auto leading-relaxed">
            I am always open to new opportunities to learn, grow, and provide innovative solutions to complex problems. 
            Whether you have a project in mind or just want to discuss the future of tech, I'm all ears.
          </p>
        </div>
        
        <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
          <a href="#contact" class="px-10 py-4 bg-primary text-dark font-black uppercase tracking-widest text-xs rounded-2xl hover:bg-white transition-all duration-300">
            Get in Touch
          </a>
          <span class="text-light/20 font-display text-xl">OR</span>
          <div class="flex items-center gap-4 px-8 py-4 bg-light/5 border border-light/10 rounded-2xl">
            <span class="w-2 h-2 rounded-full bg-secondary animate-pulse"></span>
            <span class="text-light/50 text-[0.65rem] font-bold uppercase tracking-widest">Open for Collaboration</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const btn = document.getElementById('reveal-email');
  const emailDisplay = document.getElementById('email-display');
  const revealIcon = document.getElementById('reveal-icon');
  
  // Obfuscate the string slightly in code
  const u = ["k", "i", "b", "e", "t", "n", "a", "t"].join("");
  const d = ["g", "m", "a", "i", "l", ".", "c", "o", "m"].join(""); 

  let revealed = false;

  btn?.addEventListener('click', () => {
    const fullEmail = `${u}@${d}`;
    
    if (!revealed) {
      if (emailDisplay) {
        emailDisplay.innerText = fullEmail;
        emailDisplay.classList.remove('text-light/40');
        emailDisplay.classList.add('text-primary', 'font-bold');
      }
      
      // Update icon to checkmark
      if (revealIcon) {
        revealIcon.innerHTML = `
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
        `;
      }

      navigator.clipboard.writeText(fullEmail);
      revealed = true;

      // Reset after 5 seconds
      setTimeout(() => {
        if (emailDisplay) {
          emailDisplay.innerText = "ki...[at]...com";
          emailDisplay.classList.add('text-light/40');
          emailDisplay.classList.remove('text-primary', 'font-bold');
        }
        if (revealIcon) {
          revealIcon.innerHTML = `
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-primary group-hover:text-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
            </svg>
          `;
        }
        revealed = false;
      }, 5000);
    } else {
      navigator.clipboard.writeText(fullEmail);
    }
  });
</script>
